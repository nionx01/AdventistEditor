{
  "name": "adventist-editor",
  "productName": "AdventistEditor",
  "version": "0.1.1",
  "description": "Edit Long Videos Into Social-Ready Content",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron-forge start",
    "make": "electron-builder --win",
    "publish": "electron-builder --win --publish always",
    "package": "electron-forge package",
    "lint": "echo \"No linter configured yet\""
  },
  "keywords": [
    "video-editor",
    "electron",
    "social-media",
    "subtitles",
    "ffmpeg"
  ],
  "author": "nionx01",
  "license": "MIT",
  "build": {
    "appId": "com.adventisteditor.app",
    "productName": "AdventistEditor",
    "copyright": "Copyright 2026 nionx01",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/AdventistEditorLogo.ico",
      "artifactName": "AdventistEditorSetup-${version}.exe",
      "executableName": "AdventistEditor",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AdventistEditor",
      "installerIcon": "src/assets/AdventistEditorLogo.ico",
      "uninstallerIcon": "src/assets/AdventistEditorLogo.ico",
      "installerHeaderIcon": "src/assets/AdventistEditorLogo.ico",
      "license": "LICENSE",
      "deleteAppDataOnUninstall": false,
      "artifactName": "AdventistEditorSetup-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "nionx01",
      "repo": "AdventistEditor",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/publisher-github": "^7.2.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.2"
  }
}
